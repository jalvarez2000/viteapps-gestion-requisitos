# Base de datos (Neon Postgres)
# neondb_owner = usado solo por Prisma CLI (migraciones)
# app_user     = usado en runtime por la API (RLS activo)
DATABASE_URL="postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require"
DATABASE_APP_URL="postgresql://app_user:<password>@<host>.neon.tech/neondb?sslmode=require"

# URLs locales
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WEB_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3002"

# Gmail OAuth2
# Obtener refresh token: node scripts/get-gmail-token.mjs
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REFRESH_TOKEN=""
GMAIL_TARGET_ADDRESS=""

# Cron
# Generar: openssl rand -hex 32
CRON_SECRET=""

# Vercel AI Gateway (OIDC)
# Auto-provisionado: cd apps/api && vercel link && vercel env pull .env.local
# VERCEL_OIDC_TOKEN=

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID_XS=""
STRIPE_PRICE_ID_S=""
STRIPE_PRICE_ID_M=""
STRIPE_PRICE_ID_L=""
STRIPE_PRICE_ID_XL=""
