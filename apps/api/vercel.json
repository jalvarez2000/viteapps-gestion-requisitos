{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm --filter api build",
  "ignoreCommand": "node scripts/skip-ci.js",
  "crons": [
    {
      "path": "/api/cron/gmail",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/backup",
      "schedule": "0 2 * * *"
    }
  ]
}
