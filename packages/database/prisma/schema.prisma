generator client {
  provider        = "prisma-client"
  output          = "../generated"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum VersionStatus {
  OPEN
  FROZEN
  TAGGED
}

enum RequirementStatus {
  PENDING
  CONFIRMED
  NOT_IMPLEMENTABLE
}

enum EmailType {
  NEW_APP
  NEW_REQUIREMENTS
  REQUIREMENT_COMMENTS
}

// ─────────────────────────────────────────
// PROJECT
// A client application being managed.
// ─────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  name        String   @unique
  clientEmail String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions     Version[]
  emailLogs    EmailLog[]
  reviewCycles ReviewCycle[]
}

// ─────────────────────────────────────────
// VERSION
// Release version within a project.
// OPEN → FROZEN → TAGGED (irreversible).
// FROZEN can revert to OPEN.
// Each freeze auto-creates the next version.
// ─────────────────────────────────────────

model Version {
  id        String        @id @default(cuid())
  projectId String
  number    Int
  status    VersionStatus @default(OPEN)
  tagName   String?
  taggedAt  DateTime?
  frozenAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groups       RequirementGroup[]
  requirements Requirement[]
  reviewCycles ReviewCycle[]

  @@unique([projectId, number])
  @@index([projectId, status])
}

// ─────────────────────────────────────────
// REQUIREMENT GROUP
// Functional area grouping requirements.
// ─────────────────────────────────────────

model RequirementGroup {
  id          String   @id @default(cuid())
  projectId   String
  versionId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  version      Version       @relation(fields: [versionId], references: [id], onDelete: Cascade)
  requirements Requirement[]

  @@unique([versionId, name])
  @@index([projectId])
}

// ─────────────────────────────────────────
// REQUIREMENT
// Individual functional requirement.
// projectId is the RLS isolation key.
// ─────────────────────────────────────────

model Requirement {
  id            String            @id @default(cuid())
  projectId     String
  versionId     String
  groupId       String
  title         String
  description   String
  status        RequirementStatus @default(PENDING)
  reviewComment String?
  sourceEmailId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  version Version          @relation(fields: [versionId], references: [id], onDelete: Cascade)
  group   RequirementGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email   EmailLog?        @relation(fields: [sourceEmailId], references: [id])

  @@index([projectId, status])
  @@index([versionId, status])
  @@index([groupId])
}

// ─────────────────────────────────────────
// EMAIL LOG
// Record of every processed email.
// ─────────────────────────────────────────

model EmailLog {
  id             String    @id @default(cuid())
  projectId      String
  gmailMessageId String    @unique
  gmailThreadId  String
  subject        String
  fromAddress    String
  body           String
  emailType      EmailType
  appName        String?
  receivedAt     DateTime
  processedAt    DateTime  @default(now())

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirements Requirement[]

  @@index([projectId])
}

// ─────────────────────────────────────────
// REVIEW CYCLE
// One round of manager review per version.
// Repeats each time the client sends comments.
// ─────────────────────────────────────────

model ReviewCycle {
  id          String    @id @default(cuid())
  projectId   String
  versionId   String
  cycleNumber Int       @default(1)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  emailSentAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version Version @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([projectId, versionId])
}
