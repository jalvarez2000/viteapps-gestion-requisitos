generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum VersionStatus {
  OPEN
  FROZEN
  TAGGED
}

enum RequirementStatus {
  PENDING
  CONFIRMED
  NOT_IMPLEMENTABLE
}

enum EmailType {
  NEW_APP
  NEW_REQUIREMENTS
  REQUIREMENT_COMMENTS
}

enum ProjectSize {
  XS
  S
  M
  L
  XL
}

enum ProjectStatus {
  SOLICITADO
  CREANDO_ENTORNO
  ENTORNO_CONSTRUIDO
  CREANDO_CODIGO
  CODIGO_CREADO
  TESTEANDO
  TESTADO
  SUBIDO_A_STAGING
}

// ─────────────────────────────────────────
// ADMIN USER
// Internal user who manages projects.
// ─────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─────────────────────────────────────────
// PROJECT
// A client application being managed.
// ─────────────────────────────────────────

model Project {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String   @unique
  clientEmail String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  status ProjectStatus @default(SOLICITADO)

  userSize       ProjectSize?
  aiSize         ProjectSize?
  tagline        String?
  clientPassword String?

  inProduction Boolean   @default(false)
  productionAt DateTime?

  stripeProductId      String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  subscriptionStatusAt DateTime?

  versions     Version[]
  emailLogs    EmailLog[]
  reviewCycles ReviewCycle[]
  resetTokens  PasswordResetToken[]
}

// ─────────────────────────────────────────
// VERSION
// Release version within a project.
// OPEN → FROZEN → TAGGED (irreversible).
// FROZEN can revert to OPEN.
// Each freeze auto-creates the next version.
// ─────────────────────────────────────────

model Version {
  id        String        @id @default(cuid())
  projectId String
  number    Int
  status    VersionStatus @default(OPEN)
  tagName   String?
  taggedAt  DateTime?
  frozenAt  DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  project      Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  groups       RequirementGroup[]
  requirements Requirement[]
  reviewCycles ReviewCycle[]
  attachments  EmailAttachment[]
  comments     EmailComment[]

  @@unique([projectId, number])
  @@index([projectId, status])
}

// ─────────────────────────────────────────
// REQUIREMENT GROUP
// Functional area grouping requirements.
// ─────────────────────────────────────────

model RequirementGroup {
  id          String   @id @default(cuid())
  projectId   String
  versionId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  version      Version       @relation(fields: [versionId], references: [id], onDelete: Cascade)
  requirements Requirement[]

  @@unique([versionId, name])
  @@index([projectId])
}

// ─────────────────────────────────────────
// REQUIREMENT
// Individual functional requirement.
// projectId is the RLS isolation key.
// ─────────────────────────────────────────

model Requirement {
  id            String            @id @default(cuid())
  projectId     String
  versionId     String
  groupId       String
  title         String
  description   String
  status        RequirementStatus @default(PENDING)
  reviewComment String?
  sourceEmailId String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  version        Version               @relation(fields: [versionId], references: [id], onDelete: Cascade)
  group          RequirementGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  email          EmailLog?             @relation(fields: [sourceEmailId], references: [id])
  portalComments PortalComment[]
  reactions      RequirementReaction[]

  @@index([projectId, status])
  @@index([versionId, status])
  @@index([groupId])
}

// ─────────────────────────────────────────
// EMAIL LOG
// Record of every processed email.
// ─────────────────────────────────────────

model EmailLog {
  id             String    @id @default(cuid())
  projectId      String
  gmailMessageId String    @unique
  gmailThreadId  String
  subject        String
  fromAddress    String
  body           String
  emailType      EmailType
  appName        String?
  receivedAt     DateTime
  processedAt    DateTime  @default(now())

  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirements Requirement[]
  attachments  EmailAttachment[]
  comments     EmailComment[]

  @@index([projectId])
}

// ─────────────────────────────────────────
// EMAIL ATTACHMENT
// Binary/text attachments from inbound emails.
// ─────────────────────────────────────────

model EmailAttachment {
  id         String   @id @default(cuid())
  emailLogId String
  versionId  String
  filename   String
  mimeType   String
  size       Int
  data       String
  createdAt  DateTime @default(now())

  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  version  Version  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([emailLogId])
  @@index([versionId])
}

// ─────────────────────────────────────────
// EMAIL COMMENT
// Free-form observations from an email that are
// not a direct functional requirement.
// ─────────────────────────────────────────

model EmailComment {
  id         String   @id @default(cuid())
  projectId  String
  versionId  String
  emailLogId String
  body       String
  createdAt  DateTime @default(now())

  emailLog EmailLog @relation(fields: [emailLogId], references: [id], onDelete: Cascade)
  version  Version  @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([emailLogId])
  @@index([projectId, versionId])
}

// ─────────────────────────────────────────
// REVIEW CYCLE
// One round of manager review per version.
// Repeats each time the client sends comments.
// ─────────────────────────────────────────

model ReviewCycle {
  id          String    @id @default(cuid())
  projectId   String
  versionId   String
  cycleNumber Int       @default(1)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  emailSentAt DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  version Version @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([projectId, versionId])
}

// ─────────────────────────────────────────
// PASSWORD RESET TOKEN
// One-time token for portal password reset.
// ─────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  projectId String
  token     String    @unique // SHA-256 of the raw token sent to client
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

// ─────────────────────────────────────────
// PORTAL COMMENT
// Comment left by the client on a requirement.
// ─────────────────────────────────────────

model PortalComment {
  id            String   @id @default(cuid())
  projectId     String
  requirementId String
  author        String   @default("client") // "admin" | "client"
  body          String
  createdAt     DateTime @default(now())

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([requirementId])
  @@index([projectId])
}

// ─────────────────────────────────────────
// REQUIREMENT REACTION
// Emoji reaction by client on a requirement's review comment.
// ─────────────────────────────────────────

model RequirementReaction {
  id            String   @id @default(cuid())
  projectId     String
  requirementId String
  emoji         String
  createdAt     DateTime @default(now())

  requirement Requirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([requirementId, emoji])
  @@index([projectId])
}
