# ─────────────────────────────────────────
# DATABASE (Neon Postgres)
# ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─────────────────────────────────────────
# AUTH (Clerk)
# ─────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─────────────────────────────────────────
# EMAIL (Resend)
# ─────────────────────────────────────────
RESEND_TOKEN=re_...
RESEND_FROM=noreply@tudominio.com

# ─────────────────────────────────────────
# GMAIL (OAuth2 — cuenta de app)
# Obtener en: console.cloud.google.com → APIs → Gmail API → Credentials
# ─────────────────────────────────────────
GMAIL_CLIENT_ID=...apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...
GMAIL_TARGET_ADDRESS=viteappsbreizh@gmail.com

# ─────────────────────────────────────────
# CRON (Vercel inyecta este header automáticamente)
# ─────────────────────────────────────────
CRON_SECRET=un-secreto-largo-y-aleatorio

# ─────────────────────────────────────────
# VERCEL AI GATEWAY (OIDC — se obtiene con `vercel env pull`)
# NO configurar manualmente — ejecutar: vercel link && vercel env pull
# ─────────────────────────────────────────
# VERCEL_OIDC_TOKEN=  # auto-provisioned

# ─────────────────────────────────────────
# OBSERVABILITY (Sentry + Logtail — opcionales)
# ─────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# BETTERSTACK_API_KEY=...
# LOGTAIL_SOURCE_TOKEN=...

# ─────────────────────────────────────────
# BACKUPS (Vercel Blob — para el cron de backup)
# ─────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
